### 6. Generar Reporte de Ganancias de la Empresa (Requiere Token de Admin)
GET http://localhost:3000/api/admin/reportes/ganancias
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZFVzdWFyaW8iOjEwLCJyb2wiOiJFbXBsZWFkb19BZG1pbmlzdHJhdGl2byIsImlhdCI6MTc4MjY2ODMxOSwiZXhwIjoxNzgyNjk3MTE5fQ.DKdtP7UTJHLzx_MmNi25DJoRaT46mLTsIkyGxtcrsJQ

SELECT 
    COUNT(id_traslado) AS cantidad_viajes_completados, 
    SUM(ganancia_empresa) AS total_ganancia_empresa
FROM traslado
WHERE estatus = 'Finalizado' 
  AND fecha_hora >= '2026-06-01' AND fecha_hora <= '2026-06-30';
